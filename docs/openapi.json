{
  "openapi": "3.1.0",
  "info": {
    "description": "A simple Go API that provides CPU and Memory statistics, and a WebSocket stream.",
    "title": "Go System Stats API",
    "contact": {},
    "version": "1.0"
  },
  "servers": [
    {
      "url": "//localhost:8081"
    }
  ],
  "paths": {
    "/cpu": {
      "get": {
        "summary": "Get CPU usage",
        "description": "Returns the current CPU usage percentage measured over a 1-second interval",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.CpuResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/hello": {
      "get": {
        "summary": "Get a hello message",
        "description": "Returns a simple greeting message",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.HelloResponse"
                }
              }
            }
          }
        }
      }
    },
    "/memory": {
      "get": {
        "summary": "Get memory statistics",
        "description": "Returns details about the virtual memory usage of the system (total, used, available, etc.)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.MemoryResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/ws": {
      "get": {
        "summary": "Establish WebSocket connection",
        "description": "Upgrades the HTTP connection to a WebSocket. The server periodically broadcasts system memory stats (as WebsocketResponse) every 5 seconds. Connect via ws://localhost:8081/ws",
        "parameters": [
          {
            "name": "Connection",
            "in": "header",
            "description": "Upgrade",
            "required": true,
            "schema": {
              "type": "string",
              "default": "Upgrade"
            }
          },
          {
            "name": "Upgrade",
            "in": "header",
            "description": "websocket",
            "required": true,
            "schema": {
              "type": "string",
              "default": "websocket"
            }
          }
        ],
        "responses": {
          "101": {
            "description": "Switching Protocols",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/models.WebsocketResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "models.CpuResponse": {
        "type": "object",
        "properties": {
          "usage": {
            "type": "number"
          }
        }
      },
      "models.HelloResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "models.MemoryResponse": {
        "type": "object",
        "properties": {
          "available": {
            "type": "integer"
          },
          "availableGb": {
            "type": "number"
          },
          "total": {
            "type": "integer"
          },
          "totalGb": {
            "type": "number"
          },
          "used": {
            "type": "integer"
          },
          "usedGb": {
            "type": "number"
          },
          "usedPercent": {
            "type": "number"
          }
        }
      },
      "models.WebsocketResponse": {
        "type": "object",
        "properties": {
          "payload": {
            "$ref": "#/components/schemas/models.MemoryResponse"
          }
        }
      }
    }
  }
}